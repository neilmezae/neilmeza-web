# ─────────────────────────────────────────────────────────────
# neilmeza.com — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# Resend — transactional email (https://resend.com)
# Required for the /construyamos contact form to send emails.
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=

# Destination email for contact form submissions.
# Must be a verified address in your Resend account.
CONTACT_EMAIL=contact@neilmeza.com
